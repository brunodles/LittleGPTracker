FROM ubuntu:24.04

ARG DEBIAN_FRONTEND=noninteractive
ARG SDK_URL="https://github.com/simotek/rg35xx-plus-aarch64-SDL2-SDK/releases/download/0.1.0/rg35xx-plus-aarch64-SDL2-SDK-0.1.0.tar.xz"
ARG SDK_DIR="/opt/rg35xx-plus-aarch64-SDL2-SDK-0.1.0"

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git curl wget grep \
        build-essential \
        ca-certificates \
        clang-format \
        make \
        python-is-python3 \
        python3 \
        python3-pillow \
        xz-utils \
        libsdl2-dev \
        libasound2-plugins \
        libjack-dev \
    && mkdir -p "${SDK_DIR}" \
    && wget -O /tmp/rg35xx-plus-sdk.tar.xz "${SDK_URL}" \
    && tar -xvf /tmp/rg35xx-plus-sdk.tar.xz -C "${SDK_DIR}" --strip-components=1 \
    && rm -f /tmp/rg35xx-plus-sdk.tar.xz \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

ENV DEVKIT="${SDK_DIR}" \
    PATH="${SDK_DIR}/bin:${PATH}"

WORKDIR /workspace

# Source code is expected to be mounted at runtime (for example: -v "$PWD:/workspace").
CMD ["bash", "-lc", "cd projects && make PLATFORM=RG35XXPLUS"]

