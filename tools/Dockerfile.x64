FROM ubuntu:24.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git curl wget grep \
        build-essential \
        clang-format \
        make \
        python-is-python3 \
        python3 \
        python3-pillow \
        libsdl2-dev \
        libasound2-plugins \
        libjack-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Source code is expected to be mounted at runtime (for example: -v "$PWD:/workspace").
CMD ["bash", "-lc", "cd projects && make PLATFORM=X64"]

